# AI 友好型项目 — 环境变量模板
#
# 用法：复制为 .env（已加入 .gitignore），按需填写。
# 仓库代码与 .mcp.json / .codex/config.toml 通过 ${VAR} 注入。

# ===== MCP 凭据（可选 MCP 才需要）=====

# Hugging Face Token（game-asset-mcp 用）
HF_TOKEN=

# MongoDB 连接串（mongodb MCP 用）
MDB_MCP_CONNECTION_STRING=

# Atlassian / Jira / Confluence（atlassian MCP 用）
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
CONFLUENCE_URL=
CONFLUENCE_USERNAME=
CONFLUENCE_API_TOKEN=

# Godot 可执行文件路径（godot MCP 用，仅在装了 Godot 时填）
GODOT_PATH=

# ===== Anthropic / Codex API（按需）=====

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
