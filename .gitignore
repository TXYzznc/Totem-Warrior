# ===== Unity 自动生成（绝对不能提交） =====
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
[Aa]ssets/Plugins/Editor/JetBrains*

# ===== Visual Studio / Rider / VS Code 工程文件 =====
# Unity 每次打开会重新生成这些，提交了反而打架
.vs/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.rar

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# 构建产物
*.apk
*.aab
*.unitypackage
*.app
crashlytics-build.properties

# Asset bundle 缓存
[Aa]ssets/[Aa]ssetStoreTools*
[Aa]ssets/Plugins/Editor/JetBrains*

# ===== Python 虚拟环境（frame-ronin MCP 用的） =====
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# ===== MCP 工具二进制与依赖（超大，应由 install.ps1 重新拉取） =====
tools/**/*.exe
tools/**/node_modules/
tools/**/logs/
tools/**/.env
tools/**/hunyuan3d_output/
tools/**/coverage/
tools/**/test_output/

# game-asset-mcp 是第三方 MCP 工具，新机器请按 setup.md 步骤 clone
tools/game-asset-mcp/

# ===== 操作系统垃圾 =====
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ===== 环境变量与密钥（绝对不能上传） =====
.env
.env.local
.env.*.local
*.pem
*.key

# ===== 编辑器临时 =====
*.swp
*.swo
*~
