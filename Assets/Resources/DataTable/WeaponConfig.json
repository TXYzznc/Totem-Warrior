{
  "table": "WeaponConfig",
  "fields": [
    { "name": "WeaponId",    "type": "string", "desc": "主键，如 knife_basic / hammer_heavy / pistol_basic / bow_charge / energy_fist" },
    { "name": "Name",        "type": "string", "desc": "显示名称" },
    { "name": "Class",       "type": "string", "desc": "Melee / Ranged / Special" },
    { "name": "BaseDamage",  "type": "float",  "desc": "基础伤害，TattooModule scaleStat 基准" },
    { "name": "AttackSpeed", "type": "float",  "desc": "AttackSpeedModifier，叠加到 PassiveStats.AttackSpeed" },
    { "name": "Range",       "type": "float",  "desc": "近战 Hitbox 球形半径（米），远程为最大有效距离" },
    { "name": "ChargedMul",  "type": "float",  "desc": "蓄力伤害倍率，覆盖默认 1.5x" },
    { "name": "ProjectileId","type": "string", "desc": "远程武器对应飞行物 ID，近战留空" },
    { "name": "Rarity",      "type": "int",    "desc": "稀有度 0=普通 1=精良 2=稀有 3=史诗" },
    { "name": "MaxAmmo",     "type": "int",    "desc": "-1=无限（近战），远程为弹匣容量" },
    { "name": "BaseStartup", "type": "int",    "desc": "前摇帧数（60fps 基准）" },
    { "name": "BaseActive",  "type": "int",    "desc": "伤害帧数（Hitbox 开启区间）" },
    { "name": "BaseRecovery","type": "int",    "desc": "后摇帧数" },
    { "name": "RequiresCharge","type": "bool", "desc": "true=需蓄力才激活伤害判定（弓）" }
  ],
