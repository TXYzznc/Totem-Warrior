    { "Id": 3, "NPCId": "tattooist_alien",    "Type": "Tattooist", "MapTheme": "Alien", "ThemePriceMul": 1.2, "ShopStockTable": "", "InteractRadius": 2.5, "GuardRadius": 8.0, "ServiceCooldown": 30.0, "GuardSpawnId": "guard_alien",  "GuardCount1": 2, "GuardCount2": 4 },
