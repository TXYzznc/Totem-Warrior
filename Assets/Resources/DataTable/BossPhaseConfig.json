    { "name": "PhaseVFXId",           "type": "string", "desc": "阶段转换特效 ID" },
    { "name": "PhaseBGMCueId",        "type": "string", "desc": "阶段 BGM cue ID" },
    { "name": "DeathPatternRecipeId", "type": "string", "desc": "v2.1 新增：Boss 死亡时必掉的主题配方 ID（仅 PhaseIndex=3 有效，其余填空）" }
