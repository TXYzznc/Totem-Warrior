    { "name": "MaxStack",    "type": "int",    "desc": "单槽最大堆叠数；金币 = 9999，颜料 = 99，其他 = 1" },
    { "name": "BasePrice",   "type": "int",    "desc": "基础定价（coin）；供商人 ShopStockConfig 引用计算实际价格" },
    { "name": "SellRatio",   "type": "float",  "desc": "玩家出售时的回收比例（× BasePrice）；默认 0.4" }
