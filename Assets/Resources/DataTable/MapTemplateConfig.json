{
  "table": "MapTemplateConfig",
  "fields": [
    { "name": "Id",            "type": "int",    "desc": "主题模板主键（1=AI_RUINS, 2=CYBERPUNK, 3=MAGITECH）" },
    { "name": "ThemeName",     "type": "string", "desc": "主题枚举名（AI_RUINS / CYBERPUNK / MAGITECH）" },
    { "name": "MapSize",       "type": "float",  "desc": "v2.1 地图根边界尺寸（单位 m，固定 150）" },
    { "name": "MinRoomSize",   "type": "float",  "desc": "BSP 最小房间尺寸（单位 m）" },
    { "name": "BspMaxDepth",   "type": "int",    "desc": "BSP 最大递归深度（v2.1 = 4）" },
    { "name": "TerrainPoolId", "type": "int",    "desc": "地块池 ID，用于 tile 替换。MVP 暂未消费" },
    { "name": "PrefabPath",    "type": "string", "desc": "房间 Prefab 路径前缀（相对 Resources/Prefab/Map/）。MVP 留空" },
    { "name": "HudAccentColor","type": "string", "desc": "HUD 强调色（hex，如 #66CCFF）。透传字段" },
    { "name": "DominantColor", "type": "string", "desc": "主色调（hex）。透传字段" }
  ],
