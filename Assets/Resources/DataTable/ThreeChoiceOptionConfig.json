    { "name": "MinRunElapsedSec", "type": "float",   "desc": "最早出现时间(s)；0=无限制" },
    { "name": "IsUnique",         "type": "bool",    "desc": "同一 Run 内只能出现一次（pattern_recipe = true）" }
