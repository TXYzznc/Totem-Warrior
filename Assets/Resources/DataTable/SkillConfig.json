{
  "table": "SkillConfig",
  "fields": [
    { "name": "SkillId",            "type": "string", "desc": "唯一技能 ID，如 skill_fireball_01" },
    { "name": "Name",               "type": "string", "desc": "显示名称" },
    { "name": "ChargeModel",        "type": "int",    "desc": "0=纯冷却 / 1=充能 / 2=蓄力释放" },
    { "name": "Cooldown",           "type": "float",  "desc": "冷却时长(s)，ChargeModel=0 时生效" },
    { "name": "MaxCharges",         "type": "int",    "desc": "最大充能层数，ChargeModel=1 时生效" },
    { "name": "ChargeRegenTime",    "type": "float",  "desc": "单层恢复时间(s)，ChargeModel=1 时生效" },
    { "name": "HoldDuration",       "type": "float",  "desc": "蓄力满充时长(s)，ChargeModel=2 时生效" },
    { "name": "OverchargeWindow",   "type": "float",  "desc": "过载窗口时长(s)，ChargeModel=2 时生效" },
    { "name": "StartupFrames",      "type": "int",    "desc": "预备帧 (60fps 基准)" },
    { "name": "ActiveFrames",       "type": "int",    "desc": "激活帧 (60fps 基准)" },
    { "name": "RecoveryFrames",     "type": "int",    "desc": "恢复帧 (60fps 基准)" },
    { "name": "DamageMul",          "type": "float",  "desc": "伤害倍率，乘以 BaseDamage" },
    { "name": "HitShape",           "type": "string", "desc": "single / circle / line / cone" },
    { "name": "HitRadius",          "type": "float",  "desc": "命中范围半径(m)，single 时忽略" },
    { "name": "Element",            "type": "string", "desc": "元素染色：Fire / Frost / Lightning / Holy / Nature / None" },
    { "name": "CancelableByDodge",  "type": "bool",   "desc": "Startup 帧内是否允许闪避取消" },
    { "name": "ItemId",             "type": "int",    "desc": "商人出售 ItemId，0 表示非商品" }
  ],
