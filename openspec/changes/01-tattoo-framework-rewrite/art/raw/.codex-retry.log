from PIL import Image
from pathlib import Path
p = Path(r'D:\\unity\\UnityProject\\GameDesinger\\openspec\\changes\\01-tattoo-framework-rewrite\\art\\raw\\part_right_arm_v2.png')
im = Image.open(p).convert('RGBA')
outline = (0x7c, 0x8a, 0xa8)
out = Image.new('RGBA', im.size, (0,0,0,0))
pix_in = im.load()
pix_out = out.load()
w,h = im.size
for y in range(h):
    for x in range(w):
        r,g,b,a = pix_in[x,y]
        if a == 0:
            continue
        # Remove residual green/cyan chroma spill from the generated key background.
        if a < 180 and g > r + 25 and g > b + 5:
            continue
        # Pure two-tone icon: white fill, fixed blue-gray outline/interior strokes.
        brightness = (r + g + b) / 3
        saturation = max(r,g,b) - min(r,g,b)
        if brightness > 232 and saturation < 40:
            pix_out[x,y] = (255,255,255,a)
        else:
            pix_out[x,y] = (*outline,a)
out.save(p)
